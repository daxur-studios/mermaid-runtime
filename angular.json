{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "mermaid-runtime": {
      "projectType": "library",
      "root": "projects/mermaid-runtime",
      "sourceRoot": "projects/mermaid-runtime/src",
      "prefix": "mr",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/mermaid-runtime/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/mermaid-runtime/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/mermaid-runtime/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "analytics": "5638f44a-a82e-4e10-8950-81add6ca550f"
  }
}
